# ===========================================
# PRETINA BACKEND — ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Server ──────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB Atlas ───────────────────────────
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/pretina?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_EXPIRES_IN=30d

# ── Firebase Admin SDK ───────────────────────
# Download serviceAccountKey.json from Firebase Console:
# Project Settings → Service Accounts → Generate New Private Key
# Place the file at: backend/src/config/serviceAccountKey.json
FIREBASE_PROJECT_ID=pretina-656c3

# ── AWS S3 (Image Storage) ──────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=pretina-uploads

# ── Razorpay ─────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_RiTr59bwo9A8dw
RAZORPAY_KEY_SECRET=your-razorpay-secret-key

# ── Payment Settings (Controlled from Admin) ──
# These are defaults — admin can override via DB settings
PAYMENT_RAZORPAY_ENABLED=true
PAYMENT_QR_ENABLED=true
PAYMENT_COD_ENABLED=true
COD_ADVANCE_PERCENTAGE=10

# ── Business Info ────────────────────────────
BUSINESS_NAME=Pretina
BUSINESS_PHONE=8169902291
BUSINESS_EMAIL=Parinenterpeise456@gmail.com
BUSINESS_UPI_ID=your-upi-id@bank
BUSINESS_QR_IMAGE_URL=https://your-s3-bucket.s3.ap-south-1.amazonaws.com/qr-code.jpg

# ── Admin Account (for initial seed) ────────
ADMIN_NAME=Pretina Admin
ADMIN_EMAIL=admin@pretina.in
ADMIN_PASSWORD=change-this-strong-password
