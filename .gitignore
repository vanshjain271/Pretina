# =============================================================================
# Pretina V2 — Root .gitignore
# =============================================================================

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Environment Variables (NEVER COMMIT THESE) ────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
admin/.env

# ── Firebase Service Account (NEVER COMMIT) ───────────────────────────────────
backend/src/config/serviceAccountKey.json

# ── Firebase App Config (NEVER COMMIT) ────────────────────────────────────────
pretina_rn_app/google-services.json
pretina_rn_app/GoogleService-Info.plist

# ── Android Signing Keys (NEVER COMMIT) ───────────────────────────────────────
pretina_rn_app/android/app/*.jks
pretina_rn_app/android/app/*.keystore
pretina_rn_app/android/key.properties
*.p12
*.p8
*.mobileprovision
*.key

# ── Build Outputs ─────────────────────────────────────────────────────────────
admin/dist/
pretina_rn_app/android/app/build/
pretina_rn_app/ios/build/
pretina_rn_app/.expo/
pretina_rn_app/dist/
pretina_rn_app/web-build/
pretina_rn_app/.kotlin/

# ── iOS (generated by expo prebuild — do not commit) ──────────────────────────
pretina_rn_app/ios/

# ── Android (generated by expo prebuild — do not commit) ──────────────────────
pretina_rn_app/android/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
backend/uploads/

# ── OS & IDE Junk ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.tsbuildinfo

# ── Test & Coverage ───────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ──────────────────────────────────────────────────────────────────────
.metro-health-check*
expo-env.d.ts
